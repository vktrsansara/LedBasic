// =============================================================
//  02_Comet.ino — эффект «Комета»
//
//  Яркая точка летит по ленте слева направо, оставляя
//  за собой хвост из 8 пикселей с убывающей яркостью.
//  После каждого пролёта цвет кометы меняется на следующий
//  оттенок радуги, затем тёмная пауза.
//
//  Железо: лента WS2812B, ESP8266, DMA-пин GPIO3 (RX)
// =============================================================

#include <NeoPixelBus.h>
#include "LedBasic.h"

// --- настройки ---
#define NUM_LEDS  60
#define DATA_PIN   3

using MyStrip = NeoPixelBus<NeoGrbFeature, NeoEsp8266DmaWs2812xMethod>;
MyStrip strip(NUM_LEDS, DATA_PIN);

LedBasic basic(
    NUM_LEDS,
    [](uint16_t pos, uint8_t r, uint8_t g, uint8_t b) {
        strip.SetPixelColor(pos, RgbColor(r, g, b));
    },
    []{ strip.Show(); },
    []{ strip.ClearTo(RgbColor(0, 0, 0)); strip.Show(); }
);

// =============================================================
//  Скрипт: комета с хвостом
//
//  H  — оттенок хвоста (меняется после каждого пролёта)
//  P  — позиция головы (движется 0 → PIXEL)
//  V  — яркость текущего пикселя хвоста
//  T  — счётчик: номер пикселя хвоста (1..8)
//  Q  — позиция T-го пикселя хвоста (P - T)
//
//  Хвост: V начинается с 160, каждый следующий пиксель
//  умножается на 3/4 (целочисленно): 160→120→90→67→50→37→27→20
// =============================================================
const char* scriptText =
    "10 H = 0\n"
    "20 P = 0\n"

    // --- один кадр кометы ---
    "30 CLEAR\n"
    "40 V = 160\n"

    // рисуем хвост: 8 пикселей позади головы
    "50 FOR T = 1 TO 8\n"
    "60   Q = P - T\n"
    "70   IF Q >= 0 THEN SET_HSV Q , H , 255 , V\n"
    "80   V = V * 3 / 4\n"         // каждый следующий темнее x0.75
    "90 NEXT T\n"

    // голова — белая, максимальная яркость
    "100 SET P , 255 , 255 , 255\n"
    "110 WAIT 25\n"

    "120 P = P + 1\n"
    "130 IF P <= PIXEL THEN GOTO 30\n"

    // пролёт завершён: пауза → смена цвета → следующий пролёт
    "140 CLEAR\n"
    "150 WAIT 200\n"
    "160 H = H + 40\n"             // сдвиг на ~1/6 круга радуги
    "170 IF H > 255 THEN H = H - 256\n"
    "180 GOTO 20\n";

// =============================================================
void setup() {
    Serial.end();
    strip.Begin();
    strip.Show();
    basic.compileFromText(scriptText);
    basic.play();
}

void loop() {
    basic.tick();
}
