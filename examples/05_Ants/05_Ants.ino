// =============================================================
//  05_Ants.ino — эффект «Муравьиная тропа»
//
//  По ленте бегут «муравьи» — пунктирный паттерн из чередующихся
//  светлых и тёмных секций. Паттерн сдвигается каждый кадр,
//  создавая иллюзию движения. Цвет медленно меняется.
//
//  Вдохновлён: kitesurfer1404 / WS2812FX (Circus Combustus)
//
//  Железо: лента WS2812B, ESP8266, DMA-пин GPIO3 (RX)
// =============================================================

#include <NeoPixelBus.h>
#include "LedBasic.h"

// --- настройки ---
#define NUM_LEDS  60
#define DATA_PIN   3

using MyStrip = NeoPixelBus<NeoGrbFeature, NeoEsp8266DmaWs2812xMethod>;
MyStrip strip(NUM_LEDS, DATA_PIN);

LedBasic basic(
    NUM_LEDS,
    [](uint16_t pos, uint8_t r, uint8_t g, uint8_t b) {
        strip.SetPixelColor(pos, RgbColor(r, g, b));
    },
    []{ strip.Show(); },
    []{ strip.ClearTo(RgbColor(0, 0, 0)); strip.Show(); }
);

// =============================================================
//  Скрипт: муравьиная тропа
//
//  Z  — фаза сдвига (0..7), каждый кадр +1
//  H  — оттенок (медленно меняется)
//  I  — текущий пиксель в кадре
//  R  — позиция пикселя в паттерне (0..7)
//
//  Паттерн: (I + Z) % 8
//    0..3 → светлый (оттенок H)
//    4..7 → тёмный (почти чёрный)
//
//  При Z=0: светлые на 0-3, тёмные на 4-7
//  При Z=1: светлые на 7,0-2, тёмные на 3-6  (сдвиг на 1)
// =============================================================
const char* scriptText =
    "10 Z = 0\n"           // фаза сдвига
    "11 H = 160\n"         // начальный оттенок (синеватый)

    // --- кадр ---
    "20 FOR I = 0 TO PIXEL\n"
    "30   R = I + Z\n"     // позиция с учётом сдвига
    "40   R = R % 8\n"     // 0..7 (паттерн из 8 пикселей)
    "50   IF R < 4 THEN SET_HSV I , H , 255 , 200\n"   // светлый
    "60   IF R >= 4 THEN SET I , 12 , 12 , 12\n"       // тёмный
    "70 NEXT I\n"
    "80 WAIT 80\n"

    // сдвиг паттерна — «муравьи бегут»
    "90 Z = Z + 1\n"
    "100 IF Z > 7 THEN Z = 0\n"

    // медленная смена цвета
    "110 H = H + 1\n"
    "120 IF H > 255 THEN H = 0\n"
    "130 GOTO 20\n";

// =============================================================
void setup() {
    Serial.end();
    strip.Begin();
    strip.Show();
    basic.compileFromText(scriptText);
    basic.play();
}

void loop() {
    basic.tick();
}
