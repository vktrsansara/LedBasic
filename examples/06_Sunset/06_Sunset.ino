// =============================================================
//  06_Sunset.ino — эффект «Закат»
//
//  Солнце — яркий пиксель — движется по ленте слева направо.
//  Вокруг него корона: белый центр, жёлтый, оранжевый, красный.
//  Фон — фиолетово-синее небо.
//
//  В конце пути:
//    - солнце гаснет (яркость B убывает)
//    - небо темнеет (яркость W убывает)
//    - полная темнота → пауза → новый закат
//
//  Железо: лента WS2812B, ESP8266, DMA-пин GPIO3 (RX)
// =============================================================

#include <NeoPixelBus.h>
#include "LedBasic.h"

// --- настройки ---
#define NUM_LEDS  60
#define DATA_PIN   3

using MyStrip = NeoPixelBus<NeoGrbFeature, NeoEsp8266DmaWs2812xMethod>;
MyStrip strip(NUM_LEDS, DATA_PIN);

LedBasic basic(
    NUM_LEDS,
    [](uint16_t pos, uint8_t r, uint8_t g, uint8_t b) {
        strip.SetPixelColor(pos, RgbColor(r, g, b));
    },
    []{ strip.Show(); },
    []{ strip.ClearTo(RgbColor(0, 0, 0)); strip.Show(); }
);

// =============================================================
//  Скрипт: закат с движущимся солнцем
//
//  X  — позиция солнца (0 → PIXEL)
//  B  — яркость солнца (255 → 0 в конце пути)
//  W  — яркость неба (70 → 3 → 0)
//  P  — текущий пиксель в кадре
//  D  — расстояние от P до солнца X (= |X - P|, ручной ABS)
//
//  Цвет по расстоянию D:
//    D=0 → белый (центр солнца)
//    D=1 → жёлтый (корона)
//    D=2 → оранжевый
//    D=3 → красный
//    D=4 → тёмно-красный
//    D>4 → небо (W/4 , 0 , W) — фиолетово-синий
// =============================================================
const char* scriptText =
    "10 X = 0\n"           // солнце начинает слева
    "20 B = 255\n"         // полная яркость солнца
    "30 W = 70\n"          // яркость неба

    // --- кадр: рисуем все пиксели ---
    "100 P = 0\n"
    "110 D = X - P\n"
    "120 IF D < 0 THEN D = P - X\n"     // D = |X - P| (ручной ABS)

    // цвет по расстоянию от солнца (GOTO после каждого — выход из цепочки)
    "130 IF D == 0 THEN SET P , B , B , B\n"           // белый центр
    "131 IF D == 0 THEN GOTO 220\n"
    "140 IF D == 1 THEN SET P , B , B / 4 * 3 , 0\n"  // жёлтый
    "141 IF D == 1 THEN GOTO 220\n"
    "150 IF D == 2 THEN SET P , B , B / 3 , 0\n"      // оранжевый
    "151 IF D == 2 THEN GOTO 220\n"
    "160 IF D == 3 THEN SET P , B , B / 6 , 0\n"      // красный
    "161 IF D == 3 THEN GOTO 220\n"
    "170 IF D == 4 THEN SET P , B / 2 , 0 , 0\n"      // тёмно-красный
    "171 IF D == 4 THEN GOTO 220\n"
    "180 SET P , W / 4 , 0 , W\n"                     // небо

    "220 P = P + 1\n"
    "230 IF P <= PIXEL THEN GOTO 110\n"
    "240 WAIT 160\n"                    // медленный закат

    // двигаем солнце
    "250 X = X + 1\n"
    "260 IF X > PIXEL * 3 / 4 THEN B = B - 8\n"   // гаснет в последней четверти
    "270 IF B < 0 THEN B = 0\n"
    "280 IF X > PIXEL * 2 / 3 THEN W = W - 2\n"   // небо темнеет чуть раньше
    "290 IF W < 3 THEN W = 3\n"
    "300 IF X <= PIXEL THEN GOTO 100\n"

    // --- плавное затухание неба после заката ---
    "400 P = 0\n"
    "410 SET P , W / 4 , 0 , W\n"
    "420 P = P + 1\n"
    "430 IF P <= PIXEL THEN GOTO 410\n"
    "440 WAIT 80\n"
    "450 W = W - 3\n"
    "460 IF W > 0 THEN GOTO 400\n"

    // ночь
    "470 CLEAR\n"
    "480 WAIT 1200\n"
    "490 GOTO 10\n";        // новый закат

// =============================================================
void setup() {
    Serial.end();
    strip.Begin();
    strip.Show();
    basic.compileFromText(scriptText);
    basic.play();
}

void loop() {
    basic.tick();
}
